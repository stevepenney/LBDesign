# Copy this file to .env and fill in your values
# Never commit .env to version control

SECRET_KEY=your-secret-key-here
DEBUG=True

# PostgreSQL
DATABASE_URL=postgres://lumberbank_user:password@localhost:5432/lumberbank_db

# Email (for drawing upload notifications)
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_HOST_USER=your-email@example.com
EMAIL_HOST_PASSWORD=your-email-password
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=noreply@lumberbank.co.nz
DETAILING_TEAM_EMAIL=quotes@lumberbank.co.nz

# File storage
MEDIA_ROOT=media/
